{
  "name": "exchange-runner",
  "displayName": "Exchange Runner",
  "description": "Run Ruby scripts in Autodesk InfoWorks Exchange (or Innovyze IExchange) and drop into an interactive REPL.",
  "version": "0.1.0",
  "publisher": "masalab-io",
  "engines": {
    "vscode": "^1.74.0"
  },
  "icon": "media/icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Exchange Runner",
      "properties": {
        "exchangeRunner.icmExchangePath": {
          "type": "string",
          "default": "",
          "description": "Full path to ICMExchange.exe or IExchange.exe. If empty, the extension will prompt you to select one on first run."
        }
      }
    },
    "commands": [
      {
        "command": "exchangeRunner.runRubyInIcm",
        "title": "Exchange Runner: Run Ruby in Exchange",
        "icon": "$(play)"
      },
      {
        "command": "exchangeRunner.runRubyInIcmChooseExe",
        "title": "Exchange Runner: Run Ruby in Exchange (choose executable...)",
        "icon": "$(run-all)"
      },
      {
        "command": "exchangeRunner.selectExecutable",
        "title": "Exchange Runner: Select IExchange executable"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "exchangeRunner.runRubyInIcm",
          "when": "resourceLangId == ruby",
          "group": "navigation"
        },
        {
          "command": "exchangeRunner.runRubyInIcmChooseExe",
          "when": "resourceLangId == ruby",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "exchangeRunner.runRubyInIcm",
          "when": "resourceLangId == ruby",
          "group": "1_run@1"
        },
        {
          "command": "exchangeRunner.runRubyInIcmChooseExe",
          "when": "resourceLangId == ruby",
          "group": "1_run@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "exchangeRunner.runRubyInIcm",
        "key": "ctrl+alt+r",
        "when": "resourceLangId == ruby"
      },
      {
        "command": "exchangeRunner.runRubyInIcmChooseExe",
        "key": "ctrl+alt+shift+r",
        "when": "resourceLangId == ruby"
      }
    ]
  }
}
